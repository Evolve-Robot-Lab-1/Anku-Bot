<?xml version="1.0"?>
<!--
  Gazebo Plugins for Mobile Manipulator Simulation
  =================================================
  Includes:
  - Differential drive controller (2-wheel diff drive)
  - LiDAR sensor simulation
  - RGB Camera sensor simulation
  - Joint state publisher for arm joints
  - Gazebo materials & friction tuning

  Nav2 / SLAM Toolbox / MoveIt compatible
-->

<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ========================================================= -->
  <!-- MATERIALS                                                  -->
  <!-- ========================================================= -->

  <gazebo reference="body_link">
    <material>Gazebo/Red</material>
  </gazebo>

  <gazebo reference="front_left_link">
    <material>Gazebo/DarkGrey</material>
    <mu1>1.5</mu1>
    <mu2>1.5</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
  </gazebo>

  <gazebo reference="front_right_link">
    <material>Gazebo/DarkGrey</material>
    <mu1>1.5</mu1>
    <mu2>1.5</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
  </gazebo>

  <gazebo reference="back_left_link">
    <material>Gazebo/DarkGrey</material>
    <mu1>1.5</mu1>
    <mu2>1.5</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
  </gazebo>

  <gazebo reference="back_right_link">
    <material>Gazebo/DarkGrey</material>
    <mu1>1.5</mu1>
    <mu2>1.5</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
  </gazebo>

  <gazebo reference="laser_frame">
    <material>Gazebo/Black</material>
  </gazebo>

  <gazebo reference="camera_link">
    <material>Gazebo/Blue</material>
  </gazebo>

  <!-- Arm link materials -->
  <gazebo reference="static_link_1">
    <material>Gazebo/Orange</material>
  </gazebo>

  <gazebo reference="static_link_2">
    <material>Gazebo/Orange</material>
  </gazebo>

  <gazebo reference="static_link_3">
    <material>Gazebo/Orange</material>
  </gazebo>

  <gazebo reference="static_link_4">
    <material>Gazebo/Orange</material>
  </gazebo>

  <gazebo reference="static_gripper_base_link">
    <material>Gazebo/Grey</material>
  </gazebo>

  <!-- ========================================================= -->
  <!-- Differential Drive Plugin                                 -->
  <!-- ========================================================= -->

  <gazebo>
    <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">
      <ros>
        <namespace>/</namespace>
        <remapping>cmd_vel:=cmd_vel</remapping>
        <remapping>odom:=odom</remapping>
      </ros>

      <!-- Drive Wheels -->
      <left_joint>front_left_joint</left_joint>
      <right_joint>front_right_joint</right_joint>

      <!-- Kinematics -->
      <wheel_separation>0.35</wheel_separation>
      <wheel_diameter>0.15</wheel_diameter>

      <!-- Limits -->
      <max_wheel_torque>50.0</max_wheel_torque>
      <max_wheel_acceleration>2.0</max_wheel_acceleration>

      <!-- Odometry -->
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>false</publish_wheel_tf>

      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>body_link</robot_base_frame>

      <update_rate>50</update_rate>
      <odometry_source>world</odometry_source>
    </plugin>
  </gazebo>

  <!-- ========================================================= -->
  <!-- LiDAR Sensor                                              -->
  <!-- ========================================================= -->

  <gazebo reference="laser_frame">
    <sensor type="ray" name="lidar_sensor">
      <pose>0 0 0 0 0 0</pose>
      <visualize>false</visualize>
      <update_rate>10</update_rate>

      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159265359</min_angle>
            <max_angle>3.14159265359</max_angle>
          </horizontal>
        </scan>

        <range>
          <min>0.12</min>
          <max>12.0</max>
          <resolution>0.01</resolution>
        </range>

        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>

      <plugin name="lidar_plugin" filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <namespace>/</namespace>
          <remapping>~/out:=scan</remapping>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>laser_frame</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <!-- ========================================================= -->
  <!-- Camera Sensor                                              -->
  <!-- ========================================================= -->

  <gazebo reference="camera_link">
    <sensor type="camera" name="camera_sensor">
      <update_rate>30.0</update_rate>
      <visualize>false</visualize>

      <camera name="front_camera">
        <horizontal_fov>1.3962634</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.02</near>
          <far>100</far>
        </clip>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.007</stddev>
        </noise>
      </camera>

      <plugin name="camera_plugin" filename="libgazebo_ros_camera.so">
        <ros>
          <namespace>/</namespace>
          <remapping>~/image_raw:=camera/image_raw</remapping>
          <remapping>~/camera_info:=camera/camera_info</remapping>
        </ros>
        <frame_name>camera_link_optical</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <!-- ========================================================= -->
  <!-- Joint State Publisher (all joints including arm)          -->
  <!-- ========================================================= -->

  <gazebo>
    <plugin name="joint_state_publisher" filename="libgazebo_ros_joint_state_publisher.so">
      <ros>
        <namespace>/</namespace>
        <remapping>~/out:=joint_states</remapping>
      </ros>
      <update_rate>50</update_rate>

      <!-- Wheel joints -->
      <joint_name>front_left_joint</joint_name>
      <joint_name>front_right_joint</joint_name>
      <joint_name>back_left_joint</joint_name>
      <joint_name>back_right_joint</joint_name>

      <!-- Arm joints -->
      <joint_name>static_joint_1</joint_name>
      <joint_name>static_joint_2</joint_name>
      <joint_name>static_joint_3</joint_name>
      <joint_name>static_joint_4</joint_name>
      <joint_name>static_gripper_base_joint</joint_name>
      <joint_name>static_left_gear_joint</joint_name>
    </plugin>
  </gazebo>

  <!-- ========================================================= -->
  <!-- Arm Joint Trajectory Control (Gazebo simulation)           -->
  <!-- Using gazebo_ros_joint_pose_trajectory plugin               -->
  <!-- ========================================================= -->

  <gazebo>
    <plugin name="arm_trajectory_controller" filename="libgazebo_ros_joint_pose_trajectory.so">
      <ros>
        <namespace>/</namespace>
      </ros>
      <update_rate>50</update_rate>
    </plugin>
  </gazebo>

</robot>
