<?xml version="1.0"?>
<!--
  Mobile Manipulator Combined URDF
  =================================
  Integrates:
  - mobile_base_description (4-wheel differential drive)
  - arm_description (6-DOF robotic arm with gripper)

  Usage:
    ros2 launch mobile_manipulator_description display.launch.py
-->

<robot name="mobile_manipulator" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Set sim_mode=true to skip hardware ros2_control blocks from mobile_base -->
  <xacro:arg name="sim_mode" default="true"/>

  <!-- Include base (will pick up sim_mode arg) -->
  <xacro:include filename="$(find mobile_base_description)/urdf/mobile_base.urdf.xacro"/>

  <!-- Include arm macro -->
  <xacro:include filename="$(find arm_description)/urdf/arm_macro.urdf.xacro"/>

  <!-- Include lidar (local copy to avoid ydlidar_ros2_driver SDK dependency) -->
  <xacro:include filename="$(find mobile_manipulator_sim)/urdf/lidar.xacro"/>

  <xacro:include filename="$(find mobile_manipulator_sim)/urdf/gazebo.xacro"/>


  <xacro:arm_macro
    parent="arm_mount_link"
    prefix="static_"
    xyz="-0.15 0 0"
    rpy="0 0 0"/>



    

    
</robot>   