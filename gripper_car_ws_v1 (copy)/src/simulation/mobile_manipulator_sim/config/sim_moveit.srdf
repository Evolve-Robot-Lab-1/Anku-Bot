<?xml version="1.0" encoding="UTF-8"?>
<!-- MoveIt SRDF for Gazebo Simulation with static_ prefixed joints -->
<robot name="mobile_manipulator">
    <group name="arm">
        <joint name="static_joint_1"/>
        <joint name="static_joint_2"/>
        <joint name="static_joint_3"/>
        <joint name="static_joint_4"/>
        <joint name="static_gripper_base_joint"/>
    </group>
    <group name="gripper">
        <joint name="static_left_gear_joint"/>
    </group>
    <group_state name="home" group="arm">
        <joint name="static_gripper_base_joint" value="0"/>
        <joint name="static_joint_1" value="0"/>
        <joint name="static_joint_2" value="0"/>
        <joint name="static_joint_3" value="0"/>
        <joint name="static_joint_4" value="0"/>
    </group_state>
    <group_state name="ready" group="arm">
        <joint name="static_gripper_base_joint" value="-0.3645"/>
        <joint name="static_joint_1" value="-3.1416"/>
        <joint name="static_joint_2" value="0.1302"/>
        <joint name="static_joint_3" value="0.46"/>
        <joint name="static_joint_4" value="0.0434"/>
    </group_state>
    <group_state name="open" group="gripper">
        <joint name="static_left_gear_joint" value="0.8"/>
    </group_state>
    <group_state name="closed" group="gripper">
        <joint name="static_left_gear_joint" value="0"/>
    </group_state>
    <end_effector name="gripper" parent_link="static_gripper_base_link" group="gripper" parent_group="arm"/>
    <virtual_joint name="virtual_joint" type="fixed" parent_frame="arm_mount_link" child_link="static_base_link"/>
    <passive_joint name="static_left_finger_joint"/>
    <passive_joint name="static_left_joint"/>
    <passive_joint name="static_right_gear_joint"/>
    <passive_joint name="static_right_finger_joint"/>
    <passive_joint name="static_right_joint"/>
    <!-- Disable collisions -->
    <disable_collisions link1="static_base_link" link2="static_gripper_base_link" reason="Never"/>
    <disable_collisions link1="static_base_link" link2="static_link_1" reason="Adjacent"/>
    <disable_collisions link1="static_link_1" link2="static_link_2" reason="Adjacent"/>
    <disable_collisions link1="static_link_2" link2="static_link_3" reason="Adjacent"/>
    <disable_collisions link1="static_link_3" link2="static_link_4" reason="Adjacent"/>
    <disable_collisions link1="static_link_4" link2="static_gripper_base_link" reason="Adjacent"/>
</robot>
